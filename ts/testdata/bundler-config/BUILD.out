load("@aspect_rules_ts//ts:defs.bzl", "ts_config")
load("@gazelle//:def.bzl", "gazelle", "gazelle_binary")
load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools:ts.bzl", "ts_bundler_config", "ts_library", "ts_test")

# Generate //:node_modules/<pkg> targets from pnpm-lock.yaml.
npm_link_all_packages(name = "node_modules")

# Shared tsconfig referenced by every wrapper macro.
ts_config(
    name = "tsconfig",
    src = "tsconfig.json",
    visibility = ["//visibility:public"],
)

# gazelle:ts_npm_link_pattern //:node_modules/{pkg}

# Peel bundler/tooling configs out of the library compilation unit. Each
# directive emits a separate `ts_bundler_config` target so build-time deps
# (vite, vitest, tailwind) never enter the library's runtime closure, and
# accidental `import './vite.config'` from lib code fails at typecheck.
# gazelle:ts_bundler_config_pattern vite.config.* vite_config
# gazelle:ts_bundler_config_pattern vitest.config.* vitest_config
# gazelle:ts_bundler_config_pattern tailwind.config.ts tailwind_config

# All three abstract kinds → concrete wrappers in //tools:ts.bzl.
# gazelle:map_kind ts_library ts_library //tools:ts.bzl
# gazelle:map_kind ts_test ts_test //tools:ts.bzl
# gazelle:map_kind ts_bundler_config ts_bundler_config //tools:ts.bzl

gazelle_binary(
    name = "gazelle_bin",
    languages = ["@gazelle_ts//ts"],
)

gazelle(
    name = "gazelle",
    gazelle = ":gazelle_bin",
)

ts_library(
    name = "lib",
    srcs = [
        "app.ts",
        "viteHelpers.ts",
    ],
    visibility = ["//visibility:public"],
    deps = [
        "//:node_modules/@types/lodash-es",
        "//:node_modules/lodash-es",
    ],
)

ts_test(
    name = "test",
    data = [
        "app.test.ts",
        ":lib",
        "//:node_modules/@types/lodash-es",
        "//:node_modules/@types/node",
        "//:node_modules/lodash-es",
    ],
    tsconfig_types = ["node"],
)

ts_bundler_config(
    name = "vite_config",
    srcs = ["vite.config.ts"],
    visibility = ["//visibility:public"],
    deps = [
        ":lib",
        "//:node_modules/@vitejs/plugin-react",
        "//:node_modules/vite",
    ],
)

ts_bundler_config(
    name = "vitest_config",
    srcs = ["vitest.config.ts"],
    visibility = ["//visibility:public"],
    deps = ["//:node_modules/vitest"],
)

ts_bundler_config(
    name = "tailwind_config",
    srcs = ["tailwind.config.ts"],
    visibility = ["//visibility:public"],
    deps = ["//:node_modules/tailwindcss"],
)
