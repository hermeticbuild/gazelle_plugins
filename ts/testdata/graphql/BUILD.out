load("@aspect_rules_js//npm:defs.bzl", "npm_link_package")
load("@aspect_rules_ts//ts:defs.bzl", "ts_config")
load("@gazelle//:def.bzl", "gazelle", "gazelle_binary")
load("@npm//:defs.bzl", "npm_link_all_packages")

npm_link_all_packages(name = "node_modules")

# Link the codegen output as @myrepo_generated/queries inside //:node_modules
# so apps can `import` it like any pnpm-managed package.
npm_link_package(
    name = "node_modules/@myrepo_generated/queries",
    src = "//schema:queries",
    package = "@myrepo_generated/queries",
    visibility = ["//visibility:public"],
)

ts_config(
    name = "tsconfig",
    src = "tsconfig.json",
    visibility = ["//visibility:public"],
)

# gazelle:ts_npm_link_pattern //:node_modules/{pkg}
# gazelle:map_kind ts_library ts_library //tools:ts.bzl
# gazelle:map_kind ts_test ts_test //tools:ts.bzl

# Route imports of @myrepo_generated/* at the linker entries above. The
# resolver wouldn't otherwise see `@myrepo_generated/queries` because it's
# not in package.json.
# gazelle:resolve_regexp ts ^@myrepo_generated/(.*)$ //:node_modules/@myrepo_generated/$1

gazelle_binary(
    name = "gazelle_bin",
    languages = ["@gazelle_ts//ts"],
)

gazelle(
    name = "gazelle",
    gazelle = ":gazelle_bin",
)
