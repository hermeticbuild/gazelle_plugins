load("@aspect_rules_ts//ts:defs.bzl", "ts_config")
load("@gazelle//:def.bzl", "gazelle", "gazelle_binary")
load("@npm//:defs.bzl", "npm_link_all_packages")
load("//tools:ts.bzl", "ts_library", "ts_test")

# Generate //:node_modules/<pkg> targets from pnpm-lock.yaml.
npm_link_all_packages(name = "node_modules")

# Shared tsconfig referenced by every wrapper macro.
ts_config(
    name = "tsconfig",
    src = "tsconfig.json",
    visibility = ["//visibility:public"],
)

# gazelle:ts_npm_link_pattern //:node_modules/{pkg}

# All three gazelle-emitted kinds (ts_library, ts_test, ts_bundler_config)
# are abstract; wire them to our project-specific wrappers.
# gazelle:map_kind ts_library ts_library //tools:ts.bzl
# gazelle:map_kind ts_test ts_test //tools:ts.bzl

gazelle_binary(
    name = "gazelle_bin",
    languages = ["@gazelle_ts//ts"],
)

gazelle(
    name = "gazelle",
    gazelle = ":gazelle_bin",
)

ts_library(
    name = "lib",
    srcs = [
        "app.ts",
        "badge.tsx",
    ],
    visibility = ["//visibility:public"],
    deps = [
        "//:node_modules/@types/lodash-es",
        "//:node_modules/@types/node",
        "//:node_modules/@types/react",
        "//:node_modules/lodash-es",
        "//:node_modules/react",
        "//:node_modules/react-intl",
    ],
)

ts_test(
    name = "test",
    data = [
        "app.test.ts",
        ":lib",
        "//:node_modules/@types/lodash-es",
        "//:node_modules/@types/node",
        "//:node_modules/@types/react",
        "//:node_modules/lodash-es",
        "//:node_modules/react",
        "//:node_modules/react-intl",
    ],
)
