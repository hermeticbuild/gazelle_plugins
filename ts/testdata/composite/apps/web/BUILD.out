load("//tools:ts.bzl", "ts_library", "ts_test")

# Preserve the users.json fixture across gazelle runs — it's not detectable
# from imports because it's read at runtime via fs.readFile.
ts_test(
    name = "web_test",
    data = [
        "UserList.test.ts",
        "users.json",  # keep
        ":web",
        "//:node_modules/@types/node",
        "//:node_modules/@types/react",
        "//:node_modules/react",
        "//:node_modules/react-intl",
        "//packages/core",
        "//packages/utils",
    ],
)

ts_library(
    name = "web",
    srcs = ["UserList.tsx"],
    visibility = ["//visibility:public"],
    deps = [
        "//:node_modules/@types/react",
        "//:node_modules/react",
        "//:node_modules/react-intl",
        "//packages/core",
        "//packages/utils",
    ],
)
