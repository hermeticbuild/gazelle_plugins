# Windows host platform for rules_rs. Linux and macOS use the libc-free
# rust toolchain wrappers in //rust_toolchains, so the default
# @platforms//host works there. Windows still needs an ABI constraint
# because rules_rs's windows toolchains gate on it. Pinned via .bazelrc's
# common:windows --host_platform line.
platform(
    name = "local_windows_msvc",
    constraint_values = [
        "@rules_rs//rs/platforms/constraints:windows_msvc",
    ],
    parents = ["@platforms//host"],
)
